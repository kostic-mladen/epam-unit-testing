{
  "name": "epam-taf-js-practice",
  "version": "1.0.0",
  "description": "learning to setup the testing framework",
  "keywords": [
    "unit",
    "test",
    "automation",
    "wdio",
    "e2e",
    "mocha"
  ],
  "license": "ISC",
  "author": "Mladen Kostic",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "pretest": "eslint ./ --config configs/.eslintrc.json --ignore-path configs/.eslintignore",
    "test": "c8 --reporter=none --config ./configs/c8rc.json mocha --config ./configs/.mocharc.json",
    "test:only": "c8 --reporter=none --config ./configs/c8rc.json mocha --config ./configs/.mocharc.json && c8 report --config ./configs/c8rc.json",
    "posttest": "c8 report --config ./configs/c8rc.json",
    "lint": "eslint ./ --fix --config configs/.eslintrc.json --ignore-path configs/.eslintignore",
    "wdio": "wdio run ./configs/wdio.conf.js",
    "test:all": "npm test && npm run wdio",
    "epam": "wdio run ./configs/wdio.conf.js --spec test/e2e-tests/home-page.spec.js",
    "basic": "wdio run ./configs/wdio.conf.js --spec test/e2e-tests/basic-commands.spec.js",
    "advanced": "wdio run ./configs/wdio.conf.js --spec test/e2e-tests/advanced-commands.spec.js",
    "allure:open": "allure open reports/allure-report",
    "wdio:bdd": "wdio run ./configs/wdio.cucumber.conf.js",
    "wdio:bdd:smoke": "cross-env TAGS=@smoke wdio run ./configs/wdio.cucumber.conf.js",
    "wdio:bdd:regression": "cross-env TAGS=@regression wdio run ./configs/wdio.cucumber.conf.js",
    "test:all:bdd": "npm test && npm run wdio:bdd",
    "prepare": "husky"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@wdio/allure-reporter": "^9.25.0",
    "@wdio/cli": "^9.24.0",
    "@wdio/cucumber-framework": "^9.25.0",
    "@wdio/local-runner": "^9.24.0",
    "@wdio/mocha-framework": "^9.24.0",
    "@wdio/spec-reporter": "^9.24.0",
    "allure-commandline": "^2.37.0",
    "c8": "^10.1.3",
    "chai": "^4.5.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-wdio": "^9.23.0",
    "glob": "^7.2.3",
    "husky": "^9.1.7",
    "mocha": "^11.7.5",
    "mochawesome": "^7.1.4"
  }
}
